DATABASE_URL=postgresql+psycopg://xian:xian@localhost:5432/xian_house

# Boundary resolution (default: OSM/Overpass + Nominatim geocoding)
BOUNDARY_PROVIDER=osm
# Optional comma-separated Overpass mirrors; leave empty for built-in defaults
OVERPASS_URLS=
OSM_ROAD_FETCH_DELAY_SECONDS=1

# Optional Amap fallback when BOUNDARY_PROVIDER=auto, or for Gaode basemap reference
AMAP_WEB_KEY=your_amap_web_service_key
AMAP_JS_KEY=your_amap_js_api_key
AMAP_JS_SECURITY=your_amap_js_security_code

CRAWL_DELAY_SECONDS=3
